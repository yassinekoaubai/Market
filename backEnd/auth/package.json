{
  "name": "auth",
  "version": "1.0.0",
  "description": "Authentication service with Express, TypeScript, PostgreSQL, Prisma, Zod, Bcrypt, and JWT",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:seed": "node dist/prisma/seed.js",
    "generate": "prisma generate"
  },
  "keywords": ["auth", "authentication", "express", "typescript", "prisma"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
