# Environment Variables Template
# Copy this to .env and fill in your values

# GitHub Configuration
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-username
GITHUB_ORG=your-organization
GITHUB_REPO=market

# Container Registry (GHCR)
GHCR_USERNAME=your-username
GHCR_TOKEN=ghcr_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GHCR_REGISTRY=ghcr.io

# Jenkins Agent
JENKINS_AGENT_SECRET=auto-generated-by-setup
JENKINS_AGENT_NAME=docker-agent-1
JENKINS_URL=http://jenkins:8080

# Node.js Version
NODE_VERSION=20.9.0

# PostgreSQL (for testing)
POSTGRES_USER=market_user
POSTGRES_PASSWORD=market_password
POSTGRES_DB=market_test

# Service Ports (for E2E tests)
AUTH_SERVICE_PORT=3000
CATALOG_SERVICE_PORT=3001
ORDERS_SERVICE_PORT=3002

# Database Ports (for E2E tests)
AUTH_DB_PORT=5432
CATALOG_DB_PORT=5433
ORDERS_DB_PORT=5434

# Docker Registry Configuration
REGISTRY_URL=ghcr.io
REPOSITORY_OWNER=your-org

# SMTP Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=jenkins@example.com

# Build Configuration
SKIP_TESTS=false
DEPLOY_PRODUCTION=false
BUILD_TIMEOUT=3600

# Feature Flags
ENABLE_SECURITY_SCAN=true
ENABLE_CODE_QUALITY=true
ENABLE_E2E_TESTS=true
ENABLE_NOTIFICATIONS=true
